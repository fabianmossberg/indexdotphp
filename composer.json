{
    "name": "fabianmossberg/indexdotphp",
    "description": "Tiny PHP framework.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "IndexDotPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IndexDotPhp\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Fabian Mossberg",
            "email": "fabian@sleepingfox.io"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
     "scripts": {
        "pest": "./vendor/bin/pest"
     }
}
