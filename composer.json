{
    "name": "fabianmossberg/indexdotphp",
    "description": "Tiny PHP framework.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "IndexDotPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IndexDotPhp\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Fabian Mossberg",
            "email": "fabian@sleepingfox.io"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "suggest": {
        "ext-pcov": "Code coverage driver for composer test:cov. Install via 'pecl install pcov'.",
        "ext-xdebug": "Alternative coverage driver if pcov isn't available."
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
     "scripts": {
        "test": "./vendor/bin/pest",
        "test:cov": "./vendor/bin/pest --coverage --min=80"
     }
}
